# ============================================================
# VACS — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to source control.
# ============================================================

# ------ Supabase ------
# Found in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Service role key — server-side ONLY (API routes / server actions).
# This bypasses RLS, so NEVER expose it to the browser.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# ------ AI / LLM ------
# VACS supports two AI providers: Gemini (Google) and Groq (fast inference).
# Set AI_PROVIDER to 'gemini' or 'groq' to switch between them.

# Which AI provider to use: 'gemini' | 'groq'
# Gemini is the recommended default for quality grading and patient interviews.
AI_PROVIDER=gemini

# --- Option A: Google Gemini (Recommended) ---
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
# Model to use. Options: gemini-1.5-flash (fast/cheap), gemini-1.5-pro (more capable)
GEMINI_MODEL=gemini-1.5-flash

# --- Option B: Groq (Fast inference, great for interviews) ---
# Get your key at: https://console.groq.com/keys
GROQ_API_KEY=YOUR_GROQ_API_KEY
# Model to use. Options: llama-3.1-70b-versatile, mixtral-8x7b-32768
GROQ_MODEL=llama-3.1-70b-versatile

# ------ App Config ------
# Public URL of the deployed app (used for Supabase Auth redirect URLs)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Secret used to sign server-side tokens / session cookies (generate a random 32-char string)
NEXTAUTH_SECRET=GENERATE_A_RANDOM_SECRET_HERE

# ------ Feature Flags ------
# Set to 'true' to enable the demo mode bypass (unlock all days without quiz gate)
NEXT_PUBLIC_DEMO_MODE=false

# Set to 'true' to show the internal admin portal
NEXT_PUBLIC_ADMIN_ENABLED=true
